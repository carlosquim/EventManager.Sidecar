      "ContainerName": "DummyContainer",
      "LeaseContainerName": "leases",
      "TargetFunctionName": "DummyFunction"
    }
  ],
  "BlobTriggers": [
    {
      "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=dummyaccount;AccountKey=dummykey;EndpointSuffix=core.windows.net",
      "QueueName": "dummy-queue",
      "TargetFunctionName": "DummyFunction"
    }
  ],
  "EventGridTriggers": [
    {
      "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=dummyaccount;AccountKey=dummykey;EndpointSuffix=core.windows.net",
      "QueueName": "dummy-queue",
      "TargetFunctionName": "DummyFunction"
    }
  ],
  "BlobChangeFeedTriggers": [
