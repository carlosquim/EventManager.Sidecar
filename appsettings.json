      "TargetFunctionName": "DummyFunction"
    }
  ],
  "EventForwarderOptions": {
    "Mode": "Http"
  },
  "ServiceBusOptions": {
    "ConnectionString": "Endpoint=sb://dummy.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=dummykey",
