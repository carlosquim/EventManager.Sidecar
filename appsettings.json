    "HeartbeatIntervalSeconds": 15
  },
  "MainAppTargetUrl": "http://localhost:5000/",
  "APPLICATIONINSIGHTS_CONNECTION_STRING": "InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://dummy.in.applicationinsights.azure.com/;LiveEndpoint=https://dummy.livediagnostics.monitor.azure.com/;ApplicationId=00000000-0000-0000-0000-000000000000",
  "CosmosTriggers": [
    {
      "ConnectionEndpoint": "AccountEndpoint=https://dummy.documents.azure.com:443/;AccountKey=dummykey;",
